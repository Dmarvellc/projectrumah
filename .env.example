# Salin file ini menjadi .env.local lalu isi API key Anda.
# Tanpa API key, fitur AI tetap berjalan memakai generator fallback cerdas (offline).

# Dapatkan dari https://console.anthropic.com
ANTHROPIC_API_KEY=

# Opsional: ganti model (default: claude-opus-4-8)
# Pilihan: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
AI_MODEL=claude-opus-4-8

# Password login darurat dashboard (/admin/login) — fallback tanpa Firebase
ADMIN_PASSWORD=rumahplus

# Secret penandatangan cookie sesi login (wajib diganti di produksi)
SESSION_SECRET=ganti-rahasia-ini-juga

# Email pemilik: otomatis mendapat peran developer saat login/daftar
OWNER_EMAIL=

# Secret untuk endpoint cron (artikel harian & autopilot)
CRON_SECRET=ganti-rahasia-ini

# Model cepat untuk tugas mekanis (parsing, copy pendek)
AI_MODEL_FAST=claude-haiku-4-5-20251001
